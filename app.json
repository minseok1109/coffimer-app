{
  "expo": {
    "name": "Coffimer",
    "slug": "coffimer-app",
    "version": "1.0.11",
    "description": "완벽한 커피 추출을 위한 레시피와 타이머 앱",
    "platforms": ["ios", "android"],
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "coffimerapp",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#8B4513",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bangbangminseok.coffimerapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["nmap", "kakaomap", "comgooglemaps"]
      }
    },
    "android": {
      "package": "com.bangbangminseok.coffimerapp",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_1024.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "coffimer.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-audio",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Pretendard-Thin.otf",
            "./assets/fonts/Pretendard-ExtraLight.otf",
            "./assets/fonts/Pretendard-Light.otf",
            "./assets/fonts/Pretendard-Regular.otf",
            "./assets/fonts/Pretendard-Medium.otf",
            "./assets/fonts/Pretendard-SemiBold.otf",
            "./assets/fonts/Pretendard-Bold.otf",
            "./assets/fonts/Pretendard-ExtraBold.otf",
            "./assets/fonts/Pretendard-Black.otf"
          ]
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "원두 정보를 등록하기 위해 갤러리 접근 권한이 필요합니다.",
          "cameraPermission": "원두 봉투를 촬영하기 위해 카메라 접근 권한이 필요합니다.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd761fa1-092e-4338-b2e7-d8f56e757844"
      }
    },
    "runtimeVersion": "1.0.11",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/fd761fa1-092e-4338-b2e7-d8f56e757844"
    }
  }
}
